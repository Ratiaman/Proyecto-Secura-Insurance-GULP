header.header
  .header__container
    .header__left
      .header__logo
        img(src="/images/secura-insurance_logo.svg", alt="Logo")
      
      nav.header__nav
        a.header__link(href="home.html") Inicio
        a.header__link(href="renovaciones.html") Próximas renovaciones

    .header__right
      
      .header__group.header__group--user
        .header__group-trigger
          button.header__user-toggle(type="button" aria-label="Mostrar menu de perfil" aria-expanded="false")
            i.icon-user.js-user-icon
          span.header__text Mi perfil
          button.header__dropdown-toggle(type="button" aria-label="Mostrar menu de perfil" aria-expanded="false" data-menu-target=".nav-user")
            i.icon-arrow-dropdown
          
          i.header__icon-close(class=$icon-close)
        
        include ../templates/dropdown-perfil.pug
      
      
      .header__group.header__group--language
        .header__group-trigger
          i.icon-globe
          span.header__text Español
          button.header__dropdown-toggle(type="button" aria-label="Mostrar menu de idiomas" aria-expanded="false" data-menu-target=".nav-lang")
            i.icon-arrow-dropdown
        
        include ../templates/dropdown-idiomas.pug
      
      
      button.header__burger(type="button" aria-label="Cerrar menú usuario o abrir navegación")
        i.icon-burger_menu.header__burger-icon
        i.icon-close.header__burger-close

      
      input#burger-menu-toggle.burger-menu-toggle(type="checkbox" hidden)
      .nav-burger
        a.nav-burger__item(href="home.html") Inicio
        a.nav-burger__item(href="renovaciones.html") Próximas renovaciones

        //- idioma dentro del menú burger
        .nav-burger__group.nav-burger__group--language
          button.nav-burger__group-trigger(type="button" aria-expanded="false" aria-controls="burger-language-panel")
            i.icon-globe
            span.nav-burger__text Español
            i.icon-arrow-dropdown
          .nav-burger__language-panel#burger-language-panel
            include ../templates/dropdown-idiomas.pug

      .header__mobile-overlay